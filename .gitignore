# =============================================================================
# .gitignore — Pore Network Analysis Pipeline
# Author: Andrea Tonelli — https://github.com/andtoni/pore-network-analysis
# =============================================================================
# Large data files are excluded from the repository.
# Store raw data and outputs on local or institutional storage.

# ── Large data files (too large for GitHub) ───────────────────────────────────
*.tiff
*.tif
*.npy
*.pkl
*.vtp
*.vts

# ── ParaView state files (generated by Script 03) ────────────────────────────
*.pvsm

# ── CSV outputs (generated by Script 02) ─────────────────────────────────────
pore_data.csv
throat_data.csv

# ── Python environment ────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS-specific ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user

# ── Output images (regenerated by scripts) ────────────────────────────────────
outputs/
*.png

# ── Exceptions — keep example data and documentation images ──────────────────
!examples/**/*.csv
!docs/**/*.png
!docs/**/*.svg
